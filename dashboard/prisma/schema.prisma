// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// Tracks every bot event: deploy, close, claim, rebalance
model TradeEvent {
  id           Int      @id @default(autoincrement())
  ts           DateTime @default(now())
  action       String   // deploy | close | claim | rebalance
  position     String   // position address
  pool         String   // pool address
  pool_name    String?
  strategy     String?
  amount_sol   Float?   // SOL deployed
  pnl_usd      Float?   // PNL at close
  fees_usd     Float?   // fees claimed
  reason       String?  // close reason
  raw          Json?    // full metadata

  // Multi-tenant support
  wallet_id    Int?
  wallet       ManagedWallet? @relation(fields: [wallet_id], references: [id])

  @@map("trade_events")
}

// Mirror of open positions
model Position {
  id                     Int       @id @default(autoincrement())
  position               String    @unique
  pool                   String
  pool_name              String?
  strategy               String?
  amount_sol             Float?
  initial_value_usd      Float?
  total_fees_claimed_usd Float?    @default(0)
  rebalance_count        Int?      @default(0)
  volatility             Float?
  fee_tvl_ratio          Float?
  organic_score          Int?
  deployed_at            DateTime?
  closed                 Boolean   @default(false)
  closed_at              DateTime?
  out_of_range_since     DateTime?
  last_claim_at          DateTime?
  updated_at             DateTime  @updatedAt

  // Multi-tenant support
  wallet_id    Int?
  wallet       ManagedWallet? @relation(fields: [wallet_id], references: [id])

  @@map("positions")
}

// Bot heartbeat — one row, overwritten every tick
model BotStatus {
  id           Int      @id @default(1)
  last_seen    DateTime @default(now())
  is_live      Boolean  @default(false)
  dry_run      Boolean  @default(false)
  open_positions Int    @default(0)
  version      String?

  @@map("bot_status")
}

// Daily rolled-up PNL for charting the yield chart
model DailyPnl {
  id           Int      @id @default(autoincrement())
  date         String   // YYYY-MM-DD
  pnl_usd      Float    @default(0)
  fees_usd     Float    @default(0)
  trades       Int      @default(0)
  wins         Int      @default(0)
  losses       Int      @default(0)

  // Multi-tenant support
  wallet_id    Int?
  wallet       ManagedWallet? @relation(fields: [wallet_id], references: [id])

  @@unique([date, wallet_id])
  @@map("daily_pnl")
}

model User {
  id            Int             @id @default(autoincrement())
  email         String?         @unique
  wallet_addr   String          @unique // Sign-in with Solana primary wallet
  role          String          @default("user") // user | admin
  created_at    DateTime        @default(now())
  wallets       ManagedWallet[]

  @@map("users")
}

model ManagedWallet {
  id                 Int          @id @default(autoincrement())
  user_id            Int
  user               User         @relation(fields: [user_id], references: [id])
  public_key         String       @unique
  encrypted_secret   String       // AES-256 encrypted private key
  label              String?
  is_active          Boolean      @default(true)
  created_at         DateTime     @default(now())
  
  // Settings per wallet (Overrides user-config.json)
  config_override    Json?        
  
  positions          Position[]
  trade_events       TradeEvent[]
  daily_pnls         DailyPnl[]

  @@map("managed_wallets")
}

model WorkerProcess {
  worker_id        String   @id
  tenant_id        String
  wallet_id        String
  mode             String?
  channel          String?
  status           String?
  metadata         Json?
  registered_at    DateTime @default(now())
  last_seen_at     DateTime @default(now())
  lease_expires_at DateTime?

  @@map("worker_processes")
}

model WalletLease {
  tenant_id    String
  wallet_id    String
  worker_id    String
  acquired_at  DateTime @default(now())
  renewed_at   DateTime @default(now())
  expires_at   DateTime
  metadata     Json?

  @@id([tenant_id, wallet_id])
  @@index([worker_id])
  @@map("wallet_leases")
}

model WalletStorageSnapshot {
  tenant_id   String
  wallet_id   String
  store_key   String
  content     Json
  metadata    Json?
  updated_at  DateTime @default(now())

  @@id([tenant_id, wallet_id, store_key])
  @@index([store_key, updated_at(sort: Desc)])
  @@map("wallet_storage_snapshots")
}

model WorkerControlRequest {
  id           BigInt   @id @default(autoincrement())
  tenant_id    String
  wallet_id    String
  worker_id    String?
  requested_by String?
  command      String
  payload      Json?
  status       String   @default("pending")
  result       Json?
  error        String?
  created_at   DateTime @default(now())
  claimed_at   DateTime?
  completed_at DateTime?

  @@index([tenant_id, wallet_id, status, created_at])
  @@map("worker_control_requests")
}

model WorkerActivityEvent {
  id         BigInt   @id @default(autoincrement())
  tenant_id  String
  wallet_id  String
  worker_id  String?
  level      String   @default("info")
  event_type String
  message    String
  payload    Json?
  created_at DateTime @default(now())

  @@index([tenant_id, wallet_id, created_at(sort: Desc)])
  @@map("worker_activity_events")
}
